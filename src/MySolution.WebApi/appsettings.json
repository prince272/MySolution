{
  "AllowedHosts": "*",
  "AllowedOrigins": "https://localhost:7080;http://localhost:5249",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=MySolutionDb;Username=postgres;Password=postgres;"
  },
  "Authentication": {
    "Jwt": {
      "Secret": "your-jwt-secret",
      "Issuer": "MySolution.WebApi",
      "Audience": [
        "MySolution.WebApp"
      ],
      "AccessTokenExpiresIn": "00:20:00",
      "RefreshTokenExpiresIn": "30.00:00:00"
    },
    "Google": {
      "ClientId": "your-google-client-id",
      "ClientSecret": "your-google-client-secret",
      "CallbackPath": "/signin-google"
    }
  },
  "Messaging": {
    "Email": {
      "SmtpHost": "smtp.example.com",
      "Port": 587,
      "Username": "noreply@example.com",
      "Password": "your-password",
      "DisplayName": "MySolution"
    }
  }
}